@model CreateRoleViewModel
@{ 
    ViewBag.Title = "Create Role";
}
<h1>Create Role</h1>
<form asp-controller="Account" asp-action="CreateRole" method="post">
    <div asp-validation-summary="All">
    </div>
    <div class="form-group row">
        <div class="col-md-2">
            <label asp-for="RoleName" class="col-form-label"></label>
        </div>
        <div class="col-md-10">
            <input asp-for="RoleName" class="form-control" placeholder="RoleName"/>
            <span asp-validation-for="RoleName"></span>
        </div>
    </div>
    <button type="submit" class="btn btn-primary" style="width:auto">Create Role</button>
</form>