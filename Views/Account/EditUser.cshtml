@model EditUserViewModel
@{
    ViewBag.Title = "Edit User";
}
<h1>Edit User</h1>
<form asp-controller="Account" asp-action="EditUser" method="post">
    <div class="form-group row">
        <div class="col-md-2">
            <label asp-for="Id" class="col-form-label"></label>
        </div>
        <div class="col-md-10">
            <input asp-for="Id" disabled class="form-control" placeholder="Id" />
        </div>
    </div>
    <div class="form-group row">
        <div class="col-md-2">
            <label asp-for="Email" class="col-form-label"></label>
        </div>
        <div class="col-md-10">
            <input asp-for="Email" class="form-control" placeholder="Email" />
        </div>
    </div>
    <div class="form-group row">
        <div class="col-md-2">
            <label asp-for="Username" class="col-form-label"></label>
        </div>
        <div class="col-md-10">
            <input asp-for="Username" class="form-control" placeholder="Username" />
        </div>
    </div>
    <div class="form-group row">
        <div class="col-md-2">
            <label asp-for="City" class="col-form-label"></label>
        </div>
        <div class="col-md-10">
            <input asp-for="City" class="form-control" placeholder="City" />
        </div>
    </div>
    <div asp-validation-summary="All" class="text-danger">
         
    </div>
    <button type="submit" class="btn btn-primary" style="width:auto">Update</button>
    <a asp-controller="Account" asp-action="CancelEditUser" class="btn btn-primary" style="width:auto">Cancel</a>
</form>
<div class="card mt-3">
    <div class="card-header">
        <h3 class="card-title">User Roles</h3>
    </div>
    <div class="card-body">
        @if (Model.Roles.Any())
        {
            <ul>
                @foreach (var role in Model.Roles)
                {
                    <li>@role</li>
                }
            </ul>
        }
        else
        {
            <h5 class="card-title">None at the moment</h5>
        }
    </div>
    <div class="card-footer">
        <a asp-controller="Account" asp-action="ManageRole" class="btn btn-primary" style="width:auto">Manage Roles</a>
    </div>
</div>
<div class="card mt-3">
    <div class="card-header">
        <h3 class="card-title">User Claims</h3>
    </div>
    <div class="card-body">
        @if (Model.Claims.Any())
        {
            <ul>
                @foreach (var claim in Model.Claims)
                {
                    <li>claim</li>
                }
            </ul>
        }
        else
        {
    <h5 class="card-title">None at the moment</h5>
        }
    </div>
    <div class="card-footer">
        <a asp-controller="Account" asp-action="ManageClaim" class="btn btn-primary" style="width:auto">Manage Claims</a>
    </div>
</div>

