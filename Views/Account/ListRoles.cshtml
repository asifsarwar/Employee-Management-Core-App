@model IQueryable<IdentityRole>
@{ 
    ViewBag.Title = "List Roles";
}
<h1>All Roles</h1>
@if(Model.Any())
{
    foreach(var role in Model)
    {
        <div class="col-sm-12 col-md-12 col-lg-12 col-xl-12">
            <div class="card-deck">
                <div class="card mb-3">
                    <div class="card-header">
                        Role Id: @role.Id
                    </div>
                    <div class="card-body">
                        <div class="card-title">
                            <h5>@role.Name</h5>
                        </div>
                    </div>
                    <div class="card-footer">
                        <form asp-controller="Account" asp-action="DeleteRole" asp-route-id="@role.Id" method="post">
                            <a asp-controller="Account" asp-action="EditRole" asp-route-roleId="@role.Id" class="btn btn-primary" style="width:auto">Edit</a>

                            <a href="#" id="deletespan_@role.Id" class="btn btn-danger" style="width:auto" onclick="ConfirmDelete('@role.Id',true)">Delete</a>
                            <span id="confirmdelete_@role.Id" style="display:none">
                                <span>Are you sure you want to delete?</span>
                                <button type="submit" class="btn btn-danger" style="width:auto" onclick="ConfirmDelete('@role.Id',true)">Yes</button>
                                <a href="#" class="btn btn-primary" style="width:auto" onclick="ConfirmDelete('@role.Id',false)">No</a>
                            </span>
                        </form>
                    </div>
                </div>
            </div>
        </div>
    }
}
else
{
    <div class="card-deck">
        <div class="card m-3">
            <div class="card-header">
                No roles created yet
            </div>
            <div class="card-body">
                <h5 class="card-title">
                    Use the button below to create a role
                </h5>
                <a asp-controller="Account" asp-action="CreateRole" class="btn btn-primary" style="width:auto">
                    Create Role
                </a>
            </div>
            <div class="card-footer">
            </div>
        </div>
    </div>
}
@section Scripts{
<script src="~/js/CustomScript.js"></script>
 }